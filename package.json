{
  "name": "options-chatbot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev\" \"uv run --directory python-backend uvicorn main:app --reload --port 8100\"",
    "dev:next": "next dev",
    "dev:python": "uv run --directory python-backend uvicorn main:app --reload --port 8100",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "build": "next build",
    "build:clean": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\" && next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\" --max-warnings=0",
    "verify:typecheck": "tsc --noEmit --incremental false",
    "verify:deps": "uv lock --check && uv run --locked python -m pip check && npm ci --dry-run --ignore-scripts && npm audit --omit=dev --audit-level=moderate",
    "verify:python:full": "uv run --locked python -m unittest discover -s tests -p \"test_*.py\" -v",
    "verify:python:research": "uv run --locked python -m unittest tests.test_options_api_e2e tests.test_market_data_service tests.test_metric_truth_audit tests.test_expectancy_calibration tests.test_wfo_optimizer_calibration tests.test_autoresearch_cycle -v",
    "verify:python": "npm run verify:python:full",
    "verify:smoke": "uv run --locked python scripts/options_algorithm_smoke.py --fixture",
    "profit-loop:dry-report": "uv run --locked python scripts/run_profit_loop_canary.py --temp-state-dir --dry-run --report-only",
    "verify:profit-loop:dry": "uv run --locked python scripts/run_profit_loop_canary.py --temp-state-dir --dry-run --strict-gate",
    "accuracy:report": "uv run --locked python scripts/run_ai_commodity_opra_progress.py --skip-capture --skip-scan --no-write --json",
    "verify:accuracy:no-write": "uv run --locked python scripts/run_with_timeout.py --timeout-seconds 900 -- python scripts/run_ai_commodity_opra_progress.py --skip-capture --skip-scan --no-write --json --strict-gate",
    "docs:route-parity": "uv run --locked python scripts/generate_route_parity.py",
    "verify:docs": "uv run --locked python scripts/generate_route_parity.py --check",
    "verify:fast": "npm run verify:python:research && npm run daytrading:test",
    "verify:research": "npm run verify:python:research",
    "verify:full": "npm run verify:python:full && npm run daytrading:test && npm run polymarket:test && npm run verify:smoke && npm run build",
    "verify:ci:local": "npm run verify:deps && npm run verify:docs && npm run lint && npm run verify:typecheck && npm run verify:full",
    "verify:e2e:local": "npm run verify:ci:local && npm run verify:accuracy:no-write && npm run verify:profit-loop:dry",
    "verify": "npm run verify:fast",
    "daytrading:test": "node --test tests/day-trading/*.test.js",
    "polymarket:test": "node --test tests/polymarket/*.test.js",
    "options:smoke": "uv run --locked python scripts/options_algorithm_smoke.py",
    "options:experiments": "uv run --locked python scripts/options_experiment_matrix.py",
    "options:profit-lab": "uv run --locked python scripts/options_profitability_lab.py",
    "options:record": "uv run --locked python scripts/record_options_forward_truth.py --use-recommended-policy",
    "profit-loop:health": "uv run --locked python scripts/automation_operational_health.py --json",
    "profit-loop:holdout": "uv run --locked python scripts/automation_truth_holdout.py --json",
    "profit-loop:validate": "uv run --locked python scripts/automation_profit_validation.py --json",
    "profit-loop:canary": "uv run --locked python scripts/run_profit_loop_canary.py",
    "crypto:signals": "uv run --locked python -W ignore -m crypto_options.signals",
    "crypto:backtest": "uv run --locked python -W ignore -m crypto_options.signals --backtest",
    "crypto:chain": "uv run --locked python -W ignore -m crypto_options.deribit",
    "crypto:spread": "uv run --locked python -W ignore -m crypto_options.deribit --spread",
    "crypto:scan": "uv run --locked python -W ignore -m crypto_options.execution",
    "crypto:monitor": "uv run --locked python -W ignore -m crypto_options.execution --loop",
    "options:log": "uv run --locked python scripts/log_scan_picks.py"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "ethers": "^5.8.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "ws": "^8.21.0"
  }
}
